# auth-service configuration

# HTTP port the service listens on.
PORT=3200

# JWT issuer (`iss` claim). Must match the `MACP_AUTH_ISSUER` configured in the
# runtime; otherwise signature verification rejects tokens.
MACP_AUTH_ISSUER=macp-auth-service

# JWT audience (`aud` claim). Must match the `MACP_AUTH_AUDIENCE` configured in
# the runtime.
MACP_AUTH_AUDIENCE=macp-runtime

# Maximum token TTL in seconds. Clients may request a shorter TTL, but any
# request for a longer TTL is clamped to this value.
MACP_AUTH_MAX_TTL_SECONDS=3600

# Default TTL applied when the client omits `ttl_seconds`.
MACP_AUTH_DEFAULT_TTL_SECONDS=300

# RSA signing key as JSON Web Key (JWK). If unset, an *ephemeral* keypair is
# generated on startup — acceptable for local dev only. In any shared or
# long-lived deployment this MUST be provided so the key survives restarts
# and the runtime's JWKS cache stays stable.
#
# Generate with: `node -e "const {generateKeyPair,exportJWK}=require('jose'); \
#   (async()=>{const{privateKey}=await generateKeyPair('RS256',{extractable:true}); \
#   const jwk=await exportJWK(privateKey); jwk.kid='prod-key-1'; \
#   console.log(JSON.stringify(jwk))})()"`
# MACP_AUTH_SIGNING_KEY_JSON=
