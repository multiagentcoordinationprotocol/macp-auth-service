{
  "name": "macp-auth-service",
  "version": "1.0.0",
  "description": "JWT-minting identity service for the MACP runtime (RFC-MACP-0004 §4).",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "macp",
    "jwt",
    "identity",
    "auth",
    "jwks"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/multiagentcoordinationprotocol/macp-auth-service.git"
  },
  "bugs": {
    "url": "https://github.com/multiagentcoordinationprotocol/macp-auth-service/issues"
  },
  "homepage": "https://github.com/multiagentcoordinationprotocol/macp-auth-service#readme",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^5.2.1",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
